import httpx
from typing import Any, Dict

class OpenMeteoClient:
    OPEN_METEO_URL = "https://api.open-meteo.com/v1/forecast"

    WEATHER_CODE_MAP = {
        0: "Clear sky",
        1: "Mainly clear", 2: "Partly cloudy", 3: "Overcast",
        45: "Fog", 48: "Depositing rime fog",
        51: "Light drizzle", 53: "Moderate drizzle", 55: "Dense drizzle",
        56: "Light freezing drizzle", 57: "Dense freezing drizzle",
        61: "Slight rain", 63: "Moderate rain", 65: "Heavy rain",
        66: "Light freezing rain", 67: "Heavy freezing rain",
        71: "Slight snow fall", 73: "Moderate snow fall", 75: "Heavy snow fall",
        77: "Snow grains",
        80: "Slight rain showers", 81: "Moderate rain showers", 82: "Violent rain showers",
        85: "Slight snow showers", 86: "Heavy snow showers",
        95: "Thunderstorm", 96: "Thunderstorm with slight hail", 99: "Thunderstorm with heavy hail",
    }

    def __init__(self, timeout: float = 15.0):
        self.timeout = timeout

    async def fetch_uv_weather(
        self, latitude: float, longitude: float, timezone: str = "Australia/Sydney", forecast_hours: int = 12
    ) -> Dict[str, Any]:
        params = {
            "latitude": latitude,
            "longitude": longitude,
            "hourly": "temperature_2m,relative_humidity_2m,weather_code,uv_index",
            "timezone": timezone,
            "forecast_hours": forecast_hours,
        }

        async with httpx.AsyncClient(timeout=self.timeout) as client:
            resp = await client.get(self.OPEN_METEO_URL, params=params)
            resp.raise_for_status()
            data = resp.json()

        hourly = data.get("hourly", {})
        codes = hourly.get("weather_code", [])
        hourly["weather_text"] = [self.WEATHER_CODE_MAP.get(c, f"Unknown({c})") for c in codes]

        return {
            "latitude": data.get("latitude"),
            "longitude": data.get("longitude"),
            "timezone": data.get("timezone"),
            "hourly_units": data.get("hourly_units"),
            "hourly": hourly,
        }
